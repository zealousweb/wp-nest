{
	"name": "wpnest",
	"version": "1.0.2",
	"engines": {
		"node": "23.11.1"
	},
	"private": true,
	"description": "A starter theme for WordPress with modern JavaScript and CSS tooling.",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"lint:js": "eslint -c config/config.eslint.js \"sources/**/*.js\"",
		"lint:js:fix": "eslint -c config/config.eslint.js \"sources/**/*.js\" --fix",
		"lint:scss": "stylelint -c config/config.stylelint.js \"sources/**/*.scss\"",
		"lint:scss:fix": "stylelint -c config/config.stylelint.js \"sources/**/*.scss\" --fix",
		"lint": "npm run lint:js && npm run lint:scss",
		"lint:fix": "npm run lint:js:fix && npm run lint:scss:fix",
		"phpcs": "vendor/bin/phpcs",
		"phpcbf": "vendor/bin/phpcbf"
	},
	"keywords": [
		"WordPress",
		"theme",
		"starter",
		"vite",
		"sass"
	],
	"author": "admin",
	"license": "ISC",
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@fullhuman/postcss-purgecss": "8.0.0",
		"@stylistic/stylelint-plugin": "5.2.1",
		"autoprefixer": "10.5.2",
		"cssnano": "8.0.2",
		"esbuild": "0.28.1",
		"eslint": "10.6.0",
		"glob": "13.0.6",
		"globals": "17.7.0",
		"husky": "9.1.7",
		"lint-staged": "17.0.8",
		"postcss": "8.5.16",
		"sass": "1.101.0",
		"stylelint": "17.14.0",
		"stylelint-config-clean-order": "10.0.0",
		"stylelint-config-standard-scss": "17.0.0",
		"svgo": "3.3.2",
		"terser": "5.48.0",
		"vite": "8.1.3",
		"vite-plugin-checker": "0.14.4",
		"vite-plugin-image-optimizer": "1.1.8",
		"vite-plugin-live-reload": "3.1.0"
	},
	"dependencies": {
		"@fancyapps/ui": "6.1.14",
		"cspell": "10.0.1",
		"stylelint-scss": "7.2.0",
		"swiper": "14.0.1"
	},
	"lint-staged": {
		"sources/**/*.js": [
			"eslint -c config/config.eslint.js --fix"
		],
		"sources/**/*.scss": [
			"stylelint -c config/config.stylelint.js --fix"
		],
		"*.php": [
			"vendor/bin/phpcbf",
			"vendor/bin/phpcs"
		]
	}
}
